<% layout("/layouts/boilerplate") %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
    const listing = <%-JSON.stringify(listing)%>;
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    
    // Convert DB bookings to Flatpickr format with safety checks
    const bookedDates = [
        <% if(typeof bookings !== 'undefined' && bookings.length > 0) { %>
            <% for(let b of bookings) { %>
                <% if (b.checkIn && b.checkOut) { %> 
                    {
                        from: "<%= new Date(b.checkIn).toISOString().split('T')[0] %>",
                        to: "<%= new Date(b.checkOut).toISOString().split('T')[0] %>"
                    }
                    <% if(b !== bookings[bookings.length - 1]) { %>,<% } %>
                <% } %>
            <% } %>
        <% } %>
    ];
</script>

<style>
    :root {
        --brand-pink: #FF385C;
        --brand-pink-dark: #DD2E4D;
        --gold-star: #FFB400;
        --dark-text: #222222;
        --light-text: #717171;
        --border-soft: #dddddd;
    }

    .show-container { margin-top: 2rem; margin-bottom: 5rem; color: var(--dark-text); }
    .listing-title { font-weight: 700; font-size: 1.85rem; margin-bottom: 0.5rem; }
    .listing-sub { font-size: 0.95rem; display: flex; align-items: center; gap: 8px; margin-bottom: 1.5rem; }
    
    .hero-img-container {
        width: 100%; height: 500px; border-radius: 16px;
        overflow: hidden; margin-bottom: 2.5rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .hero-img-container img { width: 100%; height: 100%; object-fit: cover; }

    .content-grid { display: grid; grid-template-columns: 1.8fr 1fr; gap: 4rem; }
    .host-header { padding-bottom: 1.5rem; border-bottom: 1px solid #ebebeb; }
    .description-body { padding: 2rem 0; font-size: 1.1rem; line-height: 1.6; border-bottom: 1px solid #ebebeb; }

    .booking-sidebar {
        position: sticky; top: 100px; border: 1px solid var(--border-soft);
        border-radius: 16px; padding: 1.8rem; background: white;
        box-shadow: rgba(0, 0, 0, 0.12) 0px 6px 16px;
    }
    .btn-reserve-main {
        background: var(--brand-pink); color: white; width: 100%;
        padding: 14px; border-radius: 10px; font-weight: 700; border: none; margin-top: 1rem;
        transition: 0.2s;
    }
    .btn-reserve-main:hover { background: var(--brand-pink-dark); }
    .date-input-field { border: none; font-size: 0.9rem; width: 100%; font-weight: 600; outline: none; cursor: pointer; background: transparent; }

    .price-detail-row { display: flex; justify-content: space-between; margin-bottom: 0.75rem; color: #484848; }

    .reviews-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .review-card { padding: 1.5rem; border: 1px solid var(--border-soft); border-radius: 12px; }
    .user-profile { display: flex; align-items: center; gap: 15px; margin-bottom: 12px; }
    .user-avatar { 
        width: 44px; height: 44px; border-radius: 50%; background: #222; 
        color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; 
    }

    #map { height: 400px; width: 100%; border-radius: 12px; margin-top: 2rem; }

    @media (max-width: 992px) {
        .content-grid { grid-template-columns: 1fr; }
        .reviews-container { grid-template-columns: 1fr; }
        .booking-sidebar { position: relative; top: 0; margin-top: 2rem; }
    }
</style>

<div class="container show-container">
    <div class="row">
        <div class="col-lg-11 mx-auto">
            
            <h1 class="listing-title"><%= listing.title %></h1>
            <div class="listing-sub">
                <span style="color: var(--gold-star)"><i class="fa-solid fa-star"></i> 4.82</span> · 
                <span class="fw-bold"><%= listing.reviews.length %> reviews</span> · 
                <span class="text-decoration-underline"><%= listing.location %>, <%= listing.country %></span>
            </div>

            <div class="hero-img-container">
                <img src="<%= listing.image.url %>" alt="Listing Image">
            </div>

            <div class="content-grid">
                <div class="info-column">
                    <div class="host-header">
                        <h3 class="fw-bold">Entire home hosted by <%= listing.owner ? listing.owner.username : "WanderLust Host" %></h3>
                    </div>

                    <div class="description-body">
                        <p style="white-space: pre-line;"><%= listing.description %></p>
                    </div>

                    <% if(currUser) { %>
                    <div class="review-form-section py-5 border-bottom">
                        <h4 class="fw-bold mb-4">Leave a Review</h4>
                        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                            <div class="mb-3 mt-3">
                                <label for="rating" class="form-label">Rating</label>
                                <fieldset class="starability-slot">
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="form-floating mb-3">
                                <textarea name="review[comment]" id="comment" class="form-control" style="height: 120px" required placeholder="Comment"></textarea>
                                <label for="comment">Tell us about your stay...</label>
                            </div>
                            <button class="btn btn-outline-dark px-4">Submit Review</button>
                        </form>
                    </div>
                    <% } %>

                    <% if(listing.reviews.length > 0) { %>
                    <div class="reviews-section py-5">
                        <h3 class="fw-bold mb-4">
                            <i class="fa-solid fa-star me-2" style="color: var(--gold-star)"></i>4.82 · <%= listing.reviews.length %> reviews
                        </h3>
                        <div class="reviews-container">
                            <% for(review of listing.reviews) { %>
                                <div class="review-card">
                                    <div class="user-profile">
                                        <div class="user-avatar">
                                            <%= review.author ? review.author.username.charAt(0).toUpperCase() : 'G' %>
                                        </div>
                                        <div>
                                            <div class="fw-bold"><%= review.author ? review.author.username : "Guest" %></div>
                                            <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                        </div>
                                    </div>
                                    <p class="mb-0 small"><%= review.comment %></p>
                                    <% if (currUser && review.author && review.author._id.equals(currUser._id)) { %>
                                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <button class="btn btn-sm text-danger p-0 mt-3 fw-bold border-0 bg-transparent">Delete</button>
                                        </form>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    <% } %>
                </div>

                <div class="sidebar-column">
                    <div class="booking-sidebar">
                        <form action="/listings/<%= listing._id %>/bookings/checkout" method="POST" id="bookingForm">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <span class="fs-3 fw-bold">&#8377; <span id="basePrice"><%= listing.price.toLocaleString("en-IN") %></span></span>
                                    <span class="text-muted">night</span>
                                </div>
                            </div>
                            
                            <div class="border rounded-3 p-2 mb-3 small text-muted">
                                <div class="row g-0">
                                    <div class="col-6 border-end p-2">
                                        <b style="font-size: 0.7rem; color: #222;">CHECK-IN</b>
                                        <input type="text" name="checkIn" id="checkIn" class="date-input-field" required placeholder="Select Date">
                                    </div>
                                    <div class="col-6 p-2">
                                        <b style="font-size: 0.7rem; color: #222;">CHECKOUT</b>
                                        <input type="text" name="checkOut" id="checkOut" class="date-input-field" required placeholder="Select Date">
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn-reserve-main shadow-sm">Checkout with Stripe</button>
                            
                            <div id="priceDetail" class="mt-4 d-none">
                                <div class="price-detail-row">
                                    <span>&#8377; <%= listing.price.toLocaleString("en-IN") %> x <span id="numNights">0</span> nights</span>
                                    <span>&#8377; <span id="subtotal">0</span></span>
                                </div>
                                <div class="price-detail-row">
                                    <span class="text-decoration-underline">Service fee</span>
                                    <span>&#8377; 0</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between fw-bold fs-5">
                                    <span>Total</span>
                                    <span>&#8377; <span id="finalTotal">0</span></span>
                                </div>
                            </div>

                            <p class="text-center text-muted small mt-3 mb-0">Secure Payment via Stripe</p>
                        </form>

                        <% if (currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
                            <hr class="my-4">
                            <div class="d-flex gap-2">
                                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark rounded-pill flex-grow-1">Edit</a>
                                <form method="POST" action="/listings/<%= listing.id %>?_method=DELETE" style="flex:1;">
                                    <button class="btn btn-outline-danger rounded-pill w-100">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <hr class="my-5">
            <div class="map-area">
                <h4 class="fw-bold mb-4">Where you'll be</h4>
                <div id="map"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const checkInInput = document.getElementById('checkIn');
    const checkOutInput = document.getElementById('checkOut');
    const priceDetail = document.getElementById('priceDetail');
    const numNightsSpan = document.getElementById('numNights');
    const subtotalSpan = document.getElementById('subtotal');
    const finalTotalSpan = document.getElementById('finalTotal');
    const pricePerNight = listing.price;

    const commonConfig = {
        minDate: "today",
        dateFormat: "Y-m-d",
        disable: bookedDates,
        onChange: function() {
            updatePrice();
        }
    };

    const checkInPicker = flatpickr("#checkIn", commonConfig);
    const checkOutPicker = flatpickr("#checkOut", commonConfig);

    function updatePrice() {
        if (checkInInput.value && checkOutInput.value) {
            const d1 = new Date(checkInInput.value);
            const d2 = new Date(checkOutInput.value);

            if (d2 > d1) {
                const diff = Math.ceil((d2 - d1) / (1000 * 60 * 60 * 24));
                const total = diff * pricePerNight;
                
                numNightsSpan.innerText = diff;
                subtotalSpan.innerText = total.toLocaleString("en-IN");
                finalTotalSpan.innerText = total.toLocaleString("en-IN");
                priceDetail.classList.remove('d-none');
            } else {
                priceDetail.classList.add('d-none');
            }
        }
    }

    checkInInput.addEventListener('change', () => {
        checkOutPicker.set('minDate', checkInInput.value);
    });
</script>
<script src="/js/map.js"></script>