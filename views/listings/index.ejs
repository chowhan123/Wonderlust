<% layout("/layouts/boilerplate") %>

<style>
    /* 1. Optimized & Sticky Filter Bar */
    #filters-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background-color: #fff;
        padding: 0.5rem 0;
        position: -webkit-sticky; 
        position: sticky;
        top: 68px; 
        z-index: 10; 
        border-bottom: 1px solid #f2f2f2;   
    }
    
    @media (max-width: 768px) { #filters-container { top: 60px; } }

    #filters {
        display: flex;
        align-items: center;
        overflow-x: auto;
        padding: 0.5rem 0;
        gap: 1.5rem;
        flex-grow: 1;
        scrollbar-width: none;
    }
    #filters::-webkit-scrollbar { display: none; }

    .filter {
        text-align: center;
        opacity: 0.6;
        transition: 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: #222;
        min-width: 60px;
    }
    .filter:hover, .filter.active-filter {
        opacity: 1;
        border-bottom: 2px solid #FF385C;
        color: #FF385C;
    }
    .filter i { font-size: 1.3rem; margin-bottom: 0.2rem; }
    .filter p { font-size: 0.7rem; font-weight: 600; margin-bottom: 0; }

    /* 2. Tax Toggle Box */
    .tax-toggle-box {
        border: 1px solid #ddd;
        border-radius: 10px;
        height: 2.8rem;
        padding: 0 0.8rem;
        display: flex;
        align-items: center;
        font-size: 0.75rem;
        font-weight: 600;
        background: white;
        white-space: nowrap;
        margin-left: 1rem;
    }

    /* 3. Global Styles & Cards */
    .brand-pink { color: #FF385C !important; }
    .listing-link { text-decoration: none; color: inherit; }
    .card-img-top { border-radius: 1rem !important; object-fit: cover; transition: 0.3s ease; }
    .listing-card:hover .card-img-top { filter: brightness(92%); }

    /* 4. Badges & Share Button */
    .new-badge { top: 1rem; left: 1rem; z-index: 5; padding: 0.4rem 0.8rem; font-size: 0.7rem; }
    
    .share-btn {
        top: 1rem;
        right: 1rem;
        z-index: 9;
        background: rgba(255, 255, 255, 0.95);
        border: none;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }
    .share-btn:hover { background: white; transform: scale(1.1); box-shadow: 0 2px 8px rgba(0,0,0,0.1); }

    /* 5. Toast Notification Styles */
    #copy-toast {
        visibility: hidden;
        min-width: 200px;
        background-color: #333;
        color: #fff;
        text-align: center;
        border-radius: 50px;
        padding: 12px 24px;
        position: fixed;
        z-index: 1000;
        left: 50%;
        bottom: 50px;
        transform: translateX(-50%);
        font-size: 0.9rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    #copy-toast.show { visibility: visible; animation: fadein 0.5s, fadeout 0.5s 2s; }

    @keyframes fadein { from { bottom: 0; opacity: 0; } to { bottom: 50px; opacity: 1; } }
    @keyframes fadeout { from { bottom: 50px; opacity: 1; } to { bottom: 0; opacity: 0; } }
    @keyframes pulse-sparkle { 0% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.2); } 100% { opacity: 0.7; transform: scale(1); } }
    
    .fa-sparkles { animation: pulse-sparkle 2s infinite; color: #FFD700; }
    .tax-info { display: none; color: #717171; }
    .empty-state-wrapper { display: flex; justify-content: center; align-items: center; min-height: 70vh; width: 100%; }
    
    #backToTop { display: none; bottom: 25px; right: 25px; z-index: 99; width: 45px; height: 45px; background-color: #222; color: white; border: none; }
</style>

<div id="copy-toast"><i class="fa-solid fa-check-circle me-2"></i> Link copied to clipboard!</div>

<button id="backToTop" class="btn rounded-circle position-fixed shadow"><i class="fa-solid fa-arrow-up"></i></button>

<div id="filters-container" class="container-fluid px-md-5">
    <div id="filters">
        <% 
        const categories = [
            { id: "Trending", icon: "fa-fire" },
            { id: "Rooms", icon: "fa-bed" },
            { id: "Iconic cities", icon: "fa-mountain-city", label: "Cities" },
            { id: "Mountain", icon: "fa-mountain-sun" },
            { id: "Castles", icon: "fa-fort-awesome" },
            { id: "Amazing pools", icon: "fa-person-swimming", label: "Pools" },
            { id: "Camping", icon: "fa-tents" },
            { id: "Arctic", icon: "fa-snowflake" },
            { id: "Beachfront", icon: "fa-umbrella-beach", label: "Beach" },
        ];
        %>
        <a href="/listings" class="filter <%= !activeCategory ? 'active-filter' : '' %>">
            <div><i class="fa-solid fa-border-all"></i></div>
            <p>All</p>
        </a>
        <% for(let cat of categories) { %>
            <a href="/listings?category=<%= cat.id %>" class="filter <%= activeCategory === cat.id ? 'active-filter' : '' %>">
                <div><i class="fa-solid <%= cat.icon %>"></i></div>
                <p><%= cat.label || cat.id %></p>
            </a>
        <% } %>
    </div>

    <div class="tax-toggle-box d-none d-md-flex">
        <div class="form-check form-switch form-check-reverse">
            <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
            <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
        </div>
    </div>
</div>

<div class="container mt-3">
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% if(allListings.length > 0) { %>
            <% for(let listing of allListings) { %>
                <div class="position-relative mb-4">
                    <button class="share-btn position-absolute shadow-sm" onclick="shareListing('<%= listing.title %>', '/listings/<%= listing._id %>')">
                        <i class="fa-solid fa-arrow-up-from-bracket fs-6"></i>
                    </button>

                    <a href="/listings/<%= listing._id %>" class="listing-link">
                        <div class="card col listing-card border-0">
                            <% 
                               let timeCreated = listing._id.getTimestamp().getTime();
                               let now = Date.now();
                               let isNew = (now - timeCreated) < (24 * 60 * 60 * 1000); 
                            %>
                            <% if(isNew) { %>
                                <span class="badge rounded-pill bg-dark position-absolute new-badge d-flex align-items-center shadow">
                                    <i class="fa-solid fa-sparkles me-1"></i> New
                                </span>
                            <% } %>
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 18rem;">
                            <div class="card-body px-1">
                                <p class="card-title-text mb-0"><b><%= listing.title %></b></p>
                                <p class="text-muted small mb-0"><%= listing.location %>, <%= listing.country %></p>
                                <p class="card-price mt-1">
                                    <b>&#8377; <%= listing.price.toLocaleString("en-IN") %></b> / night
                                    <span class="tax-info"> &nbsp;+18% GST</span>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            <% } %>
        <% } else { %>
            <div class="col-12 empty-state-wrapper">
                <div class="text-center">
                    <i class="fa-regular fa-face-frown brand-pink mb-3" style="font-size: 6rem;"></i>
                    <h2 class="fw-bold">No results found</h2>
                    <p class="text-muted fs-5">Try adjusting your filters or search to find what you're looking for.</p>
                    <a href="/listings" class="btn btn-dark rounded-pill px-5 py-2 mt-3 shadow-sm">Clear all filters</a>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    // 1. Tax Toggle
    let taxSwitch = document.getElementById("flexSwitchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (let info of taxInfo) {
            info.style.display = (info.style.display !== "inline") ? "inline" : "none";
        }
    });

    // 2. Scroll to Top
    let backToTop = document.getElementById("backToTop");
    window.onscroll = function() {
        if (document.body.scrollTop > 400 || document.documentElement.scrollTop > 400) {
            backToTop.style.display = "block";
        } else {
            backToTop.style.display = "none";
        }
    };
    backToTop.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // 3. Share & Toast Logic
    async function shareListing(title, url) {
        const fullUrl = window.location.origin + url;
        if (navigator.share) {
            try {
                await navigator.share({ title: title, url: fullUrl });
            } catch (err) { console.log("Share cancelled"); }
        } else {
            navigator.clipboard.writeText(fullUrl);
            showToast();
        }
    }

    function showToast() {
        let toast = document.getElementById("copy-toast");
        toast.className = "show";
        setTimeout(() => { toast.className = toast.className.replace("show", ""); }, 2500);
    }
</script>