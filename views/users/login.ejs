<% layout("/layouts/boilerplate") %>

<div class="row mt-5 justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="login-card shadow-lg border rounded-4 bg-white">
            <div class="login-header border-bottom py-3 px-4 text-center position-relative">
                <a href="/" class="btn-close-custom position-absolute start-0 ms-3 top-50 translate-middle-y text-dark">
                    <i class="fa-solid fa-xmark"></i>
                </a>
                <span class="fw-bold small">Log in or sign up</span>
            </div>

            <div class="login-body p-4">
                <h3 class="fw-bold mb-4">Welcome to Wanderlust</h3>
                
                <form action="/login" method="POST" novalidate class="needs-validation">
                    
                    <div class="stacked-input-container mb-3">
                        <div class="input-top border p-2 px-3 rounded-top-3">
                            <label for="username" class="form-label-custom mb-0">Username</label>
                            <input name="username" id="username" type="text" 
                                   class="form-control-airbnb p-0 border-0" 
                                   placeholder="Enter username" required>
                        </div>
                        <div class="input-bottom border border-top-0 p-2 px-3 rounded-bottom-3">
                            <label for="password" class="form-label-custom mb-0">Password</label>
                            <input name="password" id="password" type="password" 
                                   class="form-control-airbnb p-0 border-0" 
                                   placeholder="••••••••" required>
                        </div>
                    </div>

                    <p class="small text-muted mb-4" style="font-size: 12px;">
                        We’ll confirm your identity to keep your account secure. Standard messaging rates apply.
                    </p>

                    <button class="btn btn-airbnb w-100 py-2 fs-5 fw-bold">Continue</button>
                    
                </form>

                <div class="text-center mt-3">
                    <p class="small">Don't have an account? 
                        <a href="/signup" class="text-dark fw-bold">Sign up</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Airbnb Specific Branding */
    :root {
        --airbnb-pink: #FF385C;
        --airbnb-gradient: linear-gradient(to right, #E61E4D 0%, #E31C5F 50%, #D70466 100%);
    }

    .login-card {
        max-width: 500px;
        margin: auto;
    }

    /* Stacked Input Logic */
    .stacked-input-container {
        border-radius: 8px;
    }

    .form-label-custom {
        font-size: 11px;
        font-weight: 600;
        color: #717171;
        text-transform: capitalize;
    }

    .form-control-airbnb {
        width: 100%;
        font-size: 15px;
        color: #222;
        background: transparent;
    }

    .form-control-airbnb:focus {
        outline: none;
        box-shadow: none;
    }

    /* Gradient Button */
    .btn-airbnb {
        background: var(--airbnb-gradient);
        border: none;
        color: white;
        border-radius: 8px;
        padding: 12px !important;
        transition: opacity 0.2s ease;
    }

    .btn-airbnb:hover {
        opacity: 0.9;
        color: white;
    }

    .btn-close-custom {
        text-decoration: none;
        font-size: 18px;
        opacity: 0.7;
    }

    /* Input focus border effect */
    .stacked-input-container div:focus-within {
        box-shadow: inset 0 0 0 2px #222;
        z-index: 2;
        position: relative;
    }
</style>